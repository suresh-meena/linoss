# Copy this file to `.env` and fill in the machines you want the repo scripts to
# manage.
#
# Machine names are free-form at the interface level (`dgx1`, `lab-box`,
# `cluster-a`), but their per-machine variables are stored under a normalized
# upper-case prefix where `-` and `.` become `_`.
#
# For example:
#   machine name: dgx1
#   variable prefix: KD_REMOTE_DGX1_
#
# Supported auth modes:
# - `key`: prefer SSH public-key auth and fall back to password when `PASSWORD`
#   is also set
# - `password`: force password auth through `sshpass`

KD_REMOTE_MACHINES=dgx1
KD_REMOTE_DEFAULT_MACHINE=dgx1
KD_REMOTE_GROUP_LAB=dgx1
# Optional centralized local state cache. Defaults to ./.remote-state
# KD_REMOTE_STATE_DIR=/home/you/projects/linoss/.remote-state
# Optional remote lease directory. Defaults to /tmp/linoss-agent-leases
# KD_REMOTE_LEASE_ROOT=/tmp/linoss-agent-leases

KD_REMOTE_DGX1_HOST=example.edu
KD_REMOTE_DGX1_USER=your-username
KD_REMOTE_DGX1_PORT=22
# Optional but recommended. If omitted, remote-shell starts in the server's
# default login directory and rsync needs explicit --dest/--source paths.
KD_REMOTE_DGX1_WORKDIR=/path/to/linoss
KD_REMOTE_DGX1_AUTH=key
KD_REMOTE_DGX1_SSH_KEY=/home/you/.ssh/id_ed25519
# Optional password fallback while keys are being rolled out.
KD_REMOTE_DGX1_PASSWORD=replace-me
# Optional metadata used for fleet selection and docs.
KD_REMOTE_DGX1_GPU_CLASS=rtx3090
KD_REMOTE_DGX1_GPU_VRAM_GIB=24
KD_REMOTE_DGX1_GPU_COUNT=2

# Example password-auth machine:
#
# KD_REMOTE_MACHINES=dgx1,lab-box
# KD_REMOTE_GROUP_3050=lab-box
# KD_REMOTE_LAB_BOX_HOST=10.0.0.5
# KD_REMOTE_LAB_BOX_USER=your-username
# KD_REMOTE_LAB_BOX_PORT=22
# KD_REMOTE_LAB_BOX_WORKDIR=/srv/kdrifting
# KD_REMOTE_LAB_BOX_AUTH=password
# KD_REMOTE_LAB_BOX_PASSWORD=replace-me
# KD_REMOTE_LAB_BOX_GPU_CLASS=rtx3050-6gb
# KD_REMOTE_LAB_BOX_GPU_VRAM_GIB=6
# KD_REMOTE_LAB_BOX_GPU_COUNT=1
