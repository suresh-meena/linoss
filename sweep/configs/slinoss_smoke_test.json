{
  "name": "slinoss-smoke-test",
  "output_root": "outputs/sweeps/slinoss-smoke-test",
  "defaults": {
    "dataset": {
      "data_dir": "data_dir",
      "use_presplit": false,
      "include_time": true,
      "T": 1.0
    },
    "training": {
      "num_steps": 2,
      "print_steps": 1,
      "lr": 0.001,
      "lr_scheduler": "identity",
      "batch_size": 2,
      "allow_tf32": false,
      "mixed_precision": false,
      "check_numerics": true,
      "weight_decay": 0.0,
      "grad_clip_norm": 1.0,
      "early_stopping_patience": 2,
      "min_steps_before_early_stop": 1,
      "dataloader_workers": 0
    },
    "model": {
      "d_model": 16,
      "n_layers": 2,
      "d_state": 16,
      "expand": 2,
      "d_head": 16,
      "d_conv": 4,
      "chunk_size": 32,
      "dropout": 0.0,
      "ffn_mult": 2
    }
  },
  "datasets": [
    {
      "name": "Heartbeat",
      "seeds": [2345]
    }
  ]
}
